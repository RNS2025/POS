// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String                 @id @default(uuid()) @db.Uuid
  name                 String
  slug                 String                 @unique
  lifecycleStatus      String                 @default("active") @map("lifecycle_status")
  archivedAt           DateTime?              @map("archived_at")
  quickpayConnectedAt  DateTime?              @map("quickpay_connected_at")
  verifoneConnectedAt  DateTime?              @map("verifone_connected_at")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  users                User[]
  quickpayConfig       TenantQuickpayConfig?
  verifoneConfig       TenantVerifoneConfig?
  platformNotes        PlatformMerchantNote[]
  platformAuditLogs    PlatformAuditLog[]
  invites              TenantInvite[]
  orders               Order[]
  kasser               Kasse[]
  categories           Category[]
  products             Product[]

  @@map("tenants")
}

model TenantQuickpayConfig {
  tenantId      String    @id @map("tenant_id") @db.Uuid
  merchantId    String    @map("merchant_id")
  privateKeyEnc String    @map("private_key_enc")
  apiKeyEnc     String    @map("api_key_enc")
  lastPingAt    DateTime? @map("last_ping_at")
  lastPingOk    Boolean?  @map("last_ping_ok")
  lastPingError String?   @map("last_ping_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_quickpay_config")
}

model TenantVerifoneConfig {
  tenantId      String    @id @map("tenant_id") @db.Uuid
  userUid       String    @map("user_uid")
  apiKeyEnc     String    @map("api_key_enc")
  poiId         String    @map("poi_id")
  saleId        String    @map("sale_id")
  useSimulator  Boolean   @default(true) @map("use_simulator")
  lastPingAt    DateTime? @map("last_ping_at")
  lastPingOk    Boolean?  @map("last_ping_ok")
  lastPingError String?   @map("last_ping_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_verifone_config")
}

model User {
  id            String                 @id @default(uuid()) @db.Uuid
  tenantId      String?                @map("tenant_id") @db.Uuid
  email         String
  passwordHash  String                 @map("password_hash")
  role          String
  displayName   String?                @map("display_name")
  pinHash       String?                @map("pin_hash")
  isActive      Boolean                @default(true) @map("is_active")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  tenant              Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformNotes       PlatformMerchantNote[] @relation("PlatformNoteAuthor")
  platformAuditLogs   PlatformAuditLog[]     @relation("PlatformAuditActor")
  staffOrders         Order[]                @relation("OrderStaff")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model PlatformMerchantNote {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author    User     @relation("PlatformNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("platform_merchant_notes")
}

model PlatformAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  actorId   String   @map("actor_id") @db.Uuid
  action    String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor     User     @relation("PlatformAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("platform_audit_logs")
}

model TenantInvite {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_invites")
}

model Kasse {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @map("tenant_id") @db.Uuid
  type                String
  name                String
  slug                String
  verifonePoiId       String?        @map("verifone_poi_id")
  payWithQrEnabled    Boolean        @default(true) @map("pay_with_qr_enabled")
  payWithSmsEnabled   Boolean        @default(false) @map("pay_with_sms_enabled")
  payWithLaterEnabled Boolean        @default(false) @map("pay_with_later_enabled")
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productKasser       ProductKasse[]
  orders              Order[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("kasser")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, name])
  @@index([tenantId, sortOrder])
  @@map("categories")
}

model Product {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  name          String
  priceOre      Int             @map("price_ore")
  categoryId    String?         @map("category_id") @db.Uuid
  imageKey      String?         @map("image_key")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  productKasser ProductKasse[]
  lineItems     OrderLineItem[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}

model ProductKasse {
  tenantId  String  @map("tenant_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  kasseId   String  @map("kasse_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  kasse     Kasse   @relation(fields: [kasseId], references: [id], onDelete: Cascade)

  @@id([productId, kasseId])
  @@index([tenantId])
  @@index([kasseId])
  @@map("product_kasse")
}

model Order {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  channel          String          @default("online")
  quickpayOrderRef String          @map("quickpay_order_ref") @db.VarChar(20)
  amountOre        Int             @map("amount_ore")
  currency         String          @default("DKK")
  status           String
  customerEmail    String?         @map("customer_email")
  customerPhone    String?         @map("customer_phone")
  paymentMethod    String?         @map("payment_method")
  description      String?
  kasseId          String?         @map("kasse_id") @db.Uuid
  staffUserId      String?         @map("staff_user_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kasse            Kasse?          @relation(fields: [kasseId], references: [id], onDelete: SetNull)
  staffUser        User?           @relation("OrderStaff", fields: [staffUserId], references: [id], onDelete: SetNull)
  payment          Payment?
  paymentActions   PaymentAction[]
  lineItems        OrderLineItem[]

  @@unique([tenantId, quickpayOrderRef])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, kasseId])
  @@index([tenantId, staffUserId])
  @@map("orders")
}

model OrderLineItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  productId    String?  @map("product_id") @db.Uuid
  nameSnapshot String   @map("name_snapshot")
  unitPriceOre Int      @map("unit_price_ore")
  quantity     Int
  lineTotalOre Int      @map("line_total_ore")
  createdAt    DateTime @default(now()) @map("created_at")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId])
  @@map("order_line_items")
}

model Payment {
  id                       String                @id @default(uuid()) @db.Uuid
  tenantId                 String                @map("tenant_id") @db.Uuid
  orderId                  String                @unique @map("order_id") @db.Uuid
  channel                  String                @default("online")
  quickpayPaymentId        Int?                  @unique @map("quickpay_payment_id")
  quickpayMerchantId       String?               @map("quickpay_merchant_id")
  verifoneTransactionId    String?               @map("verifone_transaction_id")
  verifonePoiTransactionId String?               @map("verifone_poi_transaction_id")
  verifonePoiTimestamp     DateTime?             @map("verifone_poi_timestamp")
  poiId                    String?               @map("poi_id")
  status                   String
  amountOre                Int                   @map("amount_ore")
  refundedAmountOre        Int                   @default(0) @map("refunded_amount_ore")
  paymentLinkUrl           String?               @map("payment_link_url")
  currency                 String
  lastQuickpaySyncAt       DateTime?             @map("last_quickpay_sync_at")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")
  order                    Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  webhookEvents            PaymentWebhookEvent[]
  paymentActions           PaymentAction[]

  @@index([tenantId])
  @@map("payments")
}

model PaymentAction {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  paymentId      String   @map("payment_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  amountOre      Int?     @map("amount_ore")
  status         String
  gatewayRef     String?  @map("gateway_ref")
  error          String?
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@map("payment_actions")
}

model PaymentWebhookEvent {
  id          String   @id @default(uuid()) @db.Uuid
  paymentId   String   @map("payment_id") @db.Uuid
  operationId Int      @map("operation_id")
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, operationId])
  @@map("payment_webhook_events")
}
