{
  "name": "pos-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "node -e \"try{require('fs').unlinkSync('tsconfig.tsbuildinfo')}catch(_){}\" && tsc",
    "start": "node dist/main.js",
    "start:render": "node scripts/render-start.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "seed:platform-admin": "tsx scripts/seed-platform-admin.ts",
    "seed:tenant": "tsx scripts/seed-tenant.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.13.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "prisma": "^7.8.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
