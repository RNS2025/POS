# Render — pos-api environment variables
#
# render.yaml already creates pos-api and sets:
#   NODE_ENV, DATABASE_URL, JWT_SECRET, ENCRYPTION_KEY,
#   APP_PUBLIC_URL, CORS_ORIGIN, VERIFONE_SIMULATOR
#   (+ Render auto: PORT, RENDER_EXTERNAL_URL)
#
# Copy to .env.render, fill in secrets, then paste into:
#   Render Dashboard → pos-api → Environment
#
#   cp .env.render.example .env.render
#
# Do NOT commit .env.render (gitignored).
#
# Region / database troubleshooting:
#   pos-db is in Frankfurt. pos-api MUST be in Frankfurt too for the
#   internal DATABASE_URL to work. Render cannot change region on an
#   existing web service — delete pos-api in the dashboard, add
#     region: frankfurt
#   under pos-api in render.yaml, then Blueprint → Sync to recreate it.
#   If you cannot recreate the service, set DATABASE_URL to the External
#   Database URL from pos-db (append ?sslmode=require if needed).

# --- Required (add in Render dashboard after first deploy) ---

PLATFORM_ADMIN_EMAIL=admin@rns-apps.dk
PLATFORM_ADMIN_PASSWORD=Password-1!

# --- One-time seed scripts (Render Shell: npm run seed:platform-admin / seed:tenant) ---

SEED_TENANT_NAME=Demo Shop
SEED_TENANT_SLUG=demo-shop
SEED_TENANT_EMAIL=merchant@example.com
SEED_TENANT_PASSWORD=

# --- Optional overrides (usually leave unset on Render) ---

# API_PUBLIC_URL=
# CORS_ORIGIN=https://pos-web.onrender.com,http://localhost:4200
# VERIFONE_API_URL=https://cst2.test-gsc.vfims.com
# VERIFONE_SIMULATOR=true
