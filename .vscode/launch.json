{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Express API",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/Server",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "ng serve",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "npm: start - Client",
      "url": "http://localhost:4200/"
    }
  ]
}
